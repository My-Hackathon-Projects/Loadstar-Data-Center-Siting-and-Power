{
  "name": "loadstar-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --check .",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "generate:openapi": "cd .. && python3 -m backend.api.openapi_schema --output frontend/src/types/openapi.json",
    "generate:types": "npm run generate:openapi && openapi-typescript src/types/openapi.json -o src/types/openapi.ts"
  },
  "dependencies": {
    "@deck.gl/geo-layers": "^9.3.4",
    "@deck.gl/react": "^9.3.4",
    "@tanstack/react-query": "^5.0.0",
    "maplibre-gl": "^5.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-map-gl": "^8.1.1",
    "recharts": "^2.15.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "openapi-typescript": "^7.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
